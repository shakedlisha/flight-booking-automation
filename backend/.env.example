GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Comma-separated. Add your extension origin after loading unpacked once, e.g. chrome-extension://abcdefghijklmnopqrstuvwxyz123456
CORS_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
RATE_LIMIT_PER_MINUTE=60
LOG_LEVEL=INFO
# Optional. Comma-separated secrets. If set, clients must send Authorization: Bearer <token>.
# Ignored for POST /extract when JWT_JWKS_URL, JWT_AUDIENCE, and JWT_ISSUER are all set.
EXTRACT_BEARER_TOKENS=
# Optional JWT gate (all three required to enable). Bearer must be a JWT validated via JWKS.
JWT_JWKS_URL=
JWT_AUDIENCE=
JWT_ISSUER=
# Optional single scope value that must appear in scp / scope / permissions claims.
JWT_REQUIRED_SCOPE=
# Clock skew leeway for exp (seconds).
JWT_LEEWAY_SECONDS=60
# PDF upload limits for POST /extract_pdf
PDF_MAX_BYTES=5000000
PDF_MAX_PAGES=40
# When true, scanned PDFs use Tesseract after text-layer extraction is empty (needs Poppler + Tesseract).
PDF_OCR_ENABLED=false
# Tesseract language(s), e.g. eng, deu, or eng+deu if tessdata installed.
OCR_LANG=eng
