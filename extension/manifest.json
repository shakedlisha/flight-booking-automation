{
  "manifest_version": 3,
  "name": "Flight booking paste helper",
  "version": "0.6.2",
  "description": "Paste raw booking text and fill flight booking fields via your extract API.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Booking paste"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "permissions": ["storage", "activeTab", "scripting", "identity"],
  "host_permissions": [
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*",
    "https://*.trvlhub.co.il/*"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "http://127.0.0.1:8000/*",
        "http://localhost:8000/*",
        "https://*.trvlhub.co.il/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
